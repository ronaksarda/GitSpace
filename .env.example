GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
SESSION_SECRET=change_this_to_a_random_string
PORT=3000
DATABASE_URL=sandbox # Set to 'sandbox' to run offline using the local file-backed sandbox JSON database
# USE_SANDBOX=true # Alternatively, set this to force sandbox mode
APP_URL=http://localhost:3000
# MOCK_USER_LOGIN=your_github_username
# NODE_ENV=development # Set to development to enable mock logins

